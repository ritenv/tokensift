{
  "name": "tokensift",
  "version": "0.8.0",
  "description": "Token-efficiency linter for LLM prompts and payloads",
  "keywords": ["llm", "tokens", "linter", "openai", "anthropic", "prompt-engineering"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ritenv/tokensift.git"
  },
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./matchers": {
      "import": {
        "types": "./dist/matchers.d.ts",
        "default": "./dist/matchers.js"
      },
      "require": {
        "types": "./dist/matchers.d.cts",
        "default": "./dist/matchers.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "matchers": ["./dist/matchers.d.ts"]
    }
  },
  "bin": {
    "tokensift": "./dist/cli.js"
  },
  "files": ["dist"],
  "dependencies": {
    "gpt-tokenizer": "^3.4.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "publint": "publint",
    "attw": "attw --pack .",
    "changeset": "changeset",
    "changeset:version": "changeset version && biome check --write .",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.27.11",
    "@types/node": "^26.1.1",
    "publint": "^0.2.12",
    "tsup": "^8.5.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@9.15.9",
  "pnpm": {
    "overrides": {
      "human-id": "1.0.2"
    }
  }
}
